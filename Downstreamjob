import hudson.model.*
import jenkins.model.*

//-------------------------------------------------------Utility Functions------------------------------------------------------//
def getCurrNode(nodeName)
{
  for (currNode in hudson.model.Hudson.instance.slaves)
  {
    if (currNode.nodeName == nodeName)
    {
      return currNode
    }
  }
  println("ERROR: Could not get node '" + nodeName + "'")
  return null
}

def GetNodeBuildflowCount(node)
{
  def props = node.nodeProperties.getAll(hudson.slaves.EnvironmentVariablesNodeProperty.class)
  //println ("props" + props )
  for (prop in props)
  {
    for (envvar in prop.envVars)
    {
      //println ("envvar" + envvar)
      if (envvar.key == "buildflowCount")
      {
        println("[${node.name}] Get buildflowCount = " + envvar.value)
        return envvar.value
      }
    }
  }
  return "0"
}

def SetNodeBuildflowCount(node, count)
{
  def props = node.nodeProperties.getAll(hudson.slaves.EnvironmentVariablesNodeProperty.class)
  for (prop in props)
  {
    for (envvar in prop.envVars)
    {
      if (envvar.key == "buildflowCount")
      {
        println("[${node.name}] Set buildflowCount = " + count)
  		envvar.value = count
      }
    }
  }  
}


//-------------------------------------------------------Check Parameters-------------------------------------------------------//
def asicFamilies = params["asicFamilies"].split(", ")
def build_id = params["build_id"].replaceAll("\\s","")
def skipSetup = params["Skip_Setup"]

