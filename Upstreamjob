def getCurrNode(nodeName)
{
  for (currNode in hudson.model.Hudson.instance.slaves)
  {
    if (currNode.nodeName == nodeName)
    {
      return currNode
    }
  }
  println("ERROR: Could not get node '" + nodeName + "'")
  return null
}

def isNodeReady(currNode)
{
  String label = currNode.getLabelString()
  println("label: " + label)
  if (label.indexOf("ready") > -1)
  {
    return true
  }
  else
  {
    return false
  }
}

def SetNodeBusy(currNode)
{
  String label = currNode.getLabelString()
  println("label: " + label)
  if (label.indexOf("ready") > -1)
  {
    String[] splitLabels = label.split()
    def newLabel = "";
    for (int i = 0; i < splitLabels.length; i++)
    {
      if (splitLabels[i].indexOf("ready") > -1)
      {
        println("found a ready label");
        newLabel = newLabel + " busy ";
      }
      else
      {
        newLabel = newLabel + " " + splitLabels[i] + " ";
      }
    }
    println("Setting label to: " + newLabel);
    currNode.setLabelString(newLabel);
    return true;
  }
  else
  {
    println("Could not find label 'ready'")
    return false;
  }
}


