long timeStart = System.currentTimeMillis()
long timeEnd = timeStart
while (1)
{
  timeEnd = System.currentTimeMillis()
  //Wait maximum of 12 x 60 minutes which is 12hrs for node to be 'ready'
  //This is added because PSDB and OSDB Jobs are using sames nodes and 
  //Wait period is increaded to 12hrs incase OSDB jobs are more and PSDB has to wait
  //or viceversa
  if ((timeEnd - timeStart) > 43200000)
  {
    println("Waiting too long for node to be ready. Cancelling...")
    build.state.result = FAILURE
    return
  }
  if (isNodeReady(getCurrNode(TestNode)))
  {
    println("node is ready... continue buildflow!")
    SetNodeBusy(getCurrNode(TestNode))
    break
  }
  Thread.sleep(Math.max(0, (timeEnd + 30000 - System.currentTimeMillis())));
}

